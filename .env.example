# CRA 合规平台（华南Test）环境配置（复制为 .env 后修改）
# 后端读取前缀 CRA_
CRA_SECRET_KEY=please-change-to-a-long-random-secret-string
CRA_DATABASE_URL=sqlite:///./cra.db
CRA_ACCESS_TOKEN_EXPIRE_MINUTES=720
CRA_UPLOAD_DIR=./uploads
CRA_CORS_ORIGINS=*
# 通知渠道（可选）
CRA_SMTP_HOST=
CRA_FEISHU_WEBHOOK=
# AI（可选）
CRA_ANTHROPIC_API_KEY=
CRA_OPENAI_API_KEY=
# 安全开关（生产务必保持 false / 留空）
# 仅测试/本地演示放行不安全 secret：
CRA_ALLOW_INSECURE_SECRET=false
# 仅演示环境创建 admin123 等弱密码演示账号：
CRA_ALLOW_DEMO_ACCOUNTS=false
# 生产示例（PostgreSQL）：
# CRA_DATABASE_URL=postgresql+psycopg://user:pass@db:5432/cra
# CRA_SECRET_KEY=$(openssl rand -hex 32 生成)
# CRA_CORS_ORIGINS=https://your-domain.com
